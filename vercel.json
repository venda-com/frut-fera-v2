{
  "buildCommand": null,
  "installCommand": null,
  "framework": null,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/frutiferas", "destination": "/frutiferas.html" },
    { "source": "/horta", "destination": "/horta.html" },
    { "source": "/pagina-anterior", "destination": "/pagina-anterior.html" },
    { "source": "/verdi-lite", "destination": "/verdi-lite.html" },
    { "source": "/quiz", "destination": "/cultivaragora-quiz.html" }
  ],
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
